# MedGemma Endpoint Configuration
# Copy this file to .env and fill in your values

# HuggingFace Inference Endpoint URL
# Create at: https://ui.endpoints.huggingface.co/
MEDGEMMA_ENDPOINT=https://your-endpoint.endpoints.huggingface.cloud

# HuggingFace API Token (with read access)
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: Backend type (dedicated, serverless, local)
# MEDGEMMA_BACKEND=dedicated

# Optional: Local inference server URL (if using local deployment)
# MEDGEMMA_LOCAL_URL=http://localhost:8080
