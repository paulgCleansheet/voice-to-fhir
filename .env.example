# Voice-to-Health-Record Environment Configuration
# Copy this file to .env and fill in your values

# HuggingFace API Token (required for MedGemma endpoint)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# MedGemma Endpoint URL (optional, has default)
# MEDGEMMA_ENDPOINT_URL=https://your-endpoint.aws.endpoints.huggingface.cloud
